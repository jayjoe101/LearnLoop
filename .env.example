# Supabase (auto-provisioned via Vercel Marketplace integration)
# Vercel syncs publishable-key names; either pair works locally after `vercel env pull`
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy alias (still supported)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: live Grok post generation via xAI API
XAI_API_KEY=your-xai-api-key
# Optional: override model (default: grok-3-mini-fast)
# XAI_MODEL=grok-3-mini-fast